<script type="module" src="@Assets["Components/Layout/ReconnectModal.razor.js"]"></script>

<dialog id="components-reconnect-modal"
        aria-labelledby="components-reconnect-title"
        aria-describedby="components-reconnect-message"
        data-nosnippet>
    <div class="components-reconnect-container">
        <div id="components-reconnect-animation" class="components-rejoining-animation" aria-hidden="true" hidden>
            <div></div>
            <div></div>
        </div>
        <p id="components-reconnect-eyebrow" class="components-reconnect-eyebrow" hidden></p>
        <h2 id="components-reconnect-title" class="components-reconnect-title"></h2>
        <p id="components-reconnect-message" class="components-reconnect-message"></p>
        <p id="components-reconnect-countdown" class="components-reconnect-countdown" hidden>
            Nouvelle tentative dans <span id="components-seconds-to-next-attempt"></span> secondes.
        </p>
        <div class="components-reconnect-actions">
            <button id="components-reconnect-button" type="button" hidden></button>
            <button id="components-resume-button" type="button" hidden></button>
        </div>
    </div>
</dialog>
