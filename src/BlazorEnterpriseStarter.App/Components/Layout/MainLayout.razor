@inherits LayoutComponentBase

<AppShell ProductName="BlazorEnterpriseStarter"
          Title="Blazor, architecture propre et expérience produit"
          Subtitle="Une application de démonstration conçue pour donner un aperçu rapide de la qualité d’un socle .NET moderne."
          TopBarEyebrow="Parcours"
          TopBarTitle="Trois entrées pour lire le projet rapidement"
          TopBarDescription="Explorez l’accueil, la bibliothèque UI et le backlog pour juger à la fois l’architecture, le niveau de finition et la cohérence de l’expérience.">
    <NavigationContent>
        <div class="layout-nav">
            <NavLink href="/" Match="NavLinkMatch.All" class="layout-nav__link">
                <span class="layout-nav__index">01</span>
                <span class="layout-nav__copy">
                    <strong>Accueil</strong>
                    <small>Vue d’ensemble du projet, de son positionnement et des accès essentiels.</small>
                </span>
            </NavLink>

            <NavLink href="/composants" class="layout-nav__link">
                <span class="layout-nav__index">02</span>
                <span class="layout-nav__copy">
                    <strong>Design system</strong>
                    <small>Fondations visuelles, composants réutilisables et exemples d’usage.</small>
                </span>
            </NavLink>

            <NavLink href="/backlog" class="layout-nav__link">
                <span class="layout-nav__index">03</span>
                <span class="layout-nav__copy">
                    <strong>Backlog produit</strong>
                    <small>Cas d’usage complet avec recherche, filtres, pagination et édition.</small>
                </span>
            </NavLink>
        </div>
    </NavigationContent>

    <SidebarContent>
        <div class="layout-sidebar-panel">
            <p class="layout-sidebar-panel__eyebrow">À retenir</p>
            <ul class="layout-sidebar-panel__list">
                <li>Application Blazor structurée autour d’un backend ASP.NET Core séparé</li>
                <li>Design system dédié pour les fondations visuelles et le rythme global</li>
                <li>Composants applicatifs réutilisables, cohérents et facilement lisibles</li>
                <li>Module backlog produit pensé comme un exemple métier crédible</li>
                <li>Lancement local clair via Aspire et voie Docker simple en complément</li>
            </ul>
        </div>
    </SidebarContent>

    <TopBarMetaContent>
        <div class="layout-meta">
            <span class="layout-meta__item">Blazor</span>
            <span class="layout-meta__item">ASP.NET Core</span>
            <span class="layout-meta__item">Docker</span>
            <span class="layout-meta__item">.NET Aspire</span>
        </div>
    </TopBarMetaContent>

    <ChildContent>
        @Body
    </ChildContent>
</AppShell>

<div id="blazor-error-ui" data-nosnippet>
    Une erreur inattendue est survenue.
    <a href="." class="reload">Recharger</a>
    <span class="dismiss">x</span>
</div>
