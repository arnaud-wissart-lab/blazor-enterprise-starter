@inherits LayoutComponentBase

<AppShell ProductName="BlazorEnterpriseStarter"
          Title="Démonstrateur technique .NET"
          Subtitle="Application Blazor avec API ASP.NET Core, design system réutilisable et module backlog produit."
          TopBarEyebrow="Navigation"
          TopBarTitle="Parcours de démonstration"
          TopBarDescription="L’accueil présente le projet, la bibliothèque UI expose les composants et le backlog montre un cas d’usage complet.">
    <NavigationContent>
        <div class="layout-nav">
            <NavLink href="/" Match="NavLinkMatch.All" class="layout-nav__link">
                <span class="layout-nav__index">01</span>
                <span class="layout-nav__copy">
                    <strong>Accueil</strong>
                    <small>Vue d’ensemble du projet, de l’architecture et des accès principaux.</small>
                </span>
            </NavLink>

            <NavLink href="/composants" class="layout-nav__link">
                <span class="layout-nav__index">02</span>
                <span class="layout-nav__copy">
                    <strong>Bibliothèque UI</strong>
                    <small>Fondations visuelles, composants réutilisables et états d’interface.</small>
                </span>
            </NavLink>

            <NavLink href="/backlog" class="layout-nav__link">
                <span class="layout-nav__index">03</span>
                <span class="layout-nav__copy">
                    <strong>Backlog produit</strong>
                    <small>Cas d’usage complet avec recherche, filtres, pagination et édition.</small>
                </span>
            </NavLink>
        </div>
    </NavigationContent>

    <SidebarContent>
        <div class="layout-sidebar-panel">
            <p class="layout-sidebar-panel__eyebrow">Repères</p>
            <ul class="layout-sidebar-panel__list">
                <li>Front-end Blazor et backend ASP.NET Core séparés</li>
                <li>Design system et composants applicatifs distincts</li>
                <li>Module backlog utilisé comme exemple métier démonstratif</li>
                <li>Exécution locale via Aspire, avec alternative Docker</li>
            </ul>
        </div>
    </SidebarContent>

    <TopBarMetaContent>
        <div class="layout-meta">
            <span class="layout-meta__item">Blazor</span>
            <span class="layout-meta__item">ASP.NET Core</span>
            <span class="layout-meta__item">Docker</span>
            <span class="layout-meta__item">.NET Aspire</span>
        </div>
    </TopBarMetaContent>

    <ChildContent>
        @Body
    </ChildContent>
</AppShell>

<div id="blazor-error-ui" data-nosnippet>
    Une erreur inattendue est survenue.
    <a href="." class="reload">Recharger</a>
    <span class="dismiss">x</span>
</div>
