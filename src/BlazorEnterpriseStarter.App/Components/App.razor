    <base href="/" />
    <script>
        (function () {
            try {
                const savedTheme = localStorage.getItem('bes-theme');

                if (savedTheme === 'light' || savedTheme === 'dark') {
                    document.documentElement.setAttribute('data-theme', savedTheme);
                }
            } catch {
            }
        })();
    </script>
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["_content/BlazorEnterpriseStarter.DesignSystem/styles/index.css"]" />
    <link rel="stylesheet" href="@Assets["_content/BlazorEnterpriseStarter.Components/styles/components.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["BlazorEnterpriseStarter.App.styles.css"]" />
    <ImportMap />
    <HeadOutlet />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <ReconnectModal @rendermode="InteractiveServer" />
    <script src="@Assets["scripts/theme.js"]"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>
