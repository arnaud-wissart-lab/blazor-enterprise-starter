@page "/backlog"

<PageTitle>Backlog produit</PageTitle>

<AppPageHeader Eyebrow="Module métier"
               Title="Backlog produit"
               Description="Exemple de module métier avec liste, recherche, filtres, pagination serveur et opérations CRUD.">
    <Badges>
        <AppBadge Tone="AppTone.Accent">@NombreTotalLibelle</AppBadge>
        @if (FiltreStatutActif is not null)
        {
            <AppBadge Tone="@ObtenirTonaliteStatut(FiltreStatutActif.Value)">@ObtenirLibelleStatut(FiltreStatutActif.Value)</AppBadge>
        }
        @if (FiltrePrioriteActif is not null)
        {
            <AppBadge Tone="@ObtenirTonalitePriorite(FiltrePrioriteActif.Value)">@ObtenirLibellePriorite(FiltrePrioriteActif.Value)</AppBadge>
        }
    </Badges>
    <Actions>
        <AppButton Variant="AppButtonVariant.Ghost" Href="/">Retour à l’accueil</AppButton>
        <AppButton Variant="AppButtonVariant.Secondary"
                   IsLoading="@(State.ListStatus == BacklogRequestStatus.Loading && State.HasLoadedOnce)"
                   OnClick="ActualiserAsync">
            Actualiser
        </AppButton>
        <AppButton OnClick="OuvrirCreationAsync">Créer un élément</AppButton>
    </Actions>
    <ChildContent>
        <p>La navigation latérale permet de revenir vers les autres sections sans perdre le contexte courant.</p>
    </ChildContent>
</AppPageHeader>

@if (!string.IsNullOrWhiteSpace(_messageSucces))
{
    <AppCard Eyebrow="Dernière action"
             Title="Opération réussie"
             Description="@_messageSucces"
             Tone="AppTone.Success"
             IsCompact="true">
        <ChildContent>
            <div class="backlog-state">
                <AppBadge Tone="AppTone.Success">Succès</AppBadge>
            </div>
        </ChildContent>
    </AppCard>
}

@if (State.MutationStatus == BacklogRequestStatus.Error
     && !_modaleEditionOuverte
     && !_modaleSuppressionOuverte
     && !string.IsNullOrWhiteSpace(State.MutationErrorMessage))
{
    <AppCard Eyebrow="Dernière action"
             Title="Une action n’a pas pu être finalisée"
             Description="@State.MutationErrorMessage"
             Tone="AppTone.Danger"
             IsCompact="true">
        <ChildContent>
            <div class="backlog-state">
                <AppButton Variant="AppButtonVariant.Secondary" OnClick="ActualiserAsync">Réactualiser la liste</AppButton>
            </div>
        </ChildContent>
    </AppCard>
}

<AppCard Eyebrow="Pilotage"
         Title="Filtres et tri"
         Description="Ajustez les critères pour explorer la liste et faire varier les résultats.">
    <ChildContent>
        <div class="backlog-filters">
            <AppInput Label="Recherche"
                      Placeholder="Titre, description, besoin métier..."
                      MaxLength="@BacklogInputRules.RechercheLongueurMaximale"
                      IsLoading="@AfficherIndicateurRafraichissement"
                      @bind-Value="Recherche" />

            <AppSelect Label="Statut"
                       Placeholder="Tous les statuts"
                       Options="_statutOptions"
                       @bind-Value="_statutSelectionne" />

            <AppSelect Label="Priorité"
                       Placeholder="Toutes les priorités"
                       Options="_prioriteOptions"
                       @bind-Value="_prioriteSelectionnee" />

            <AppSelect Label="Tri"
                       Placeholder=""
                       Options="_triOptions"
                       @bind-Value="_triSelectionne" />

            <AppSelect Label="Direction"
                       Placeholder=""
                       Options="_directionOptions"
                       @bind-Value="_directionSelectionnee" />
        </div>
    </ChildContent>
    <Footer>
        <div class="backlog-filters__actions">
            <AppButton Variant="AppButtonVariant.Ghost" OnClick="ReinitialiserFiltresAsync">Réinitialiser</AppButton>
            <AppButton Variant="AppButtonVariant.Secondary" OnClick="AppliquerFiltresAsync">Appliquer les filtres</AppButton>
        </div>
    </Footer>
</AppCard>

@if (AfficherEtatChargementInitial)
{
    <AppCard Eyebrow="Chargement" Title="Le backlog est en cours de chargement" Description="Les éléments sont récupérés et préparés avant affichage.">
        <ChildContent>
            <div class="backlog-state">
                <AppLoader Label="Chargement du backlog produit" />
            </div>
        </ChildContent>
    </AppCard>
}
else if (AfficherErreurPleinePage)
{
    <AppCard Eyebrow="Erreur" Title="Le backlog n’a pas pu être chargé" Description="@State.ListErrorMessage" Tone="AppTone.Danger">
        <ChildContent>
            <div class="backlog-state">
                <AppButton Variant="AppButtonVariant.Secondary" OnClick="ActualiserAsync">Réessayer</AppButton>
            </div>
        </ChildContent>
    </AppCard>
}
else
{
    @if (AfficherErreurNonBloquante)
    {
        <AppCard Eyebrow="Connexion"
                 Title="Le dernier rafraîchissement n’a pas abouti"
                 Description="@State.ListErrorMessage"
                 Tone="AppTone.Danger"
                 IsCompact="true">
            <ChildContent>
                <div class="backlog-state">
                    <AppButton Variant="AppButtonVariant.Secondary" OnClick="ActualiserAsync">Réessayer</AppButton>
                </div>
            </ChildContent>
        </AppCard>
    }

    @if (AfficherIndicateurRafraichissement)
    {
        <div class="backlog-refresh-indicator" role="status" aria-live="polite">
            <AppLoader Size="AppControlSize.Small" Inline="true" Label="Rafraîchissement des résultats" />
            <span>Mise à jour des résultats en arrière-plan…</span>
        </div>
    }

    <div class="backlog-summary-grid @(AfficherIndicateurRafraichissement ? "backlog-region--busy" : null)">
        <AppCard Title="Total filtré" Description="Nombre d’éléments correspondant aux critères en cours." IsCompact="true">
            <ChildContent>
                <div class="backlog-metric">
                    <strong>@State.TotalCount</strong>
                    <span>éléments backlog</span>
                </div>
            </ChildContent>
        </AppCard>

        <AppCard Title="Page courante" Description="Position dans la pagination serveur." IsCompact="true">
            <ChildContent>
                <div class="backlog-metric">
                    <strong>@State.CurrentPage</strong>
                    <span>sur @(State.TotalPages == 0 ? 1 : State.TotalPages)</span>
                </div>
            </ChildContent>
        </AppCard>

        <AppCard Title="Taille de page" Description="Nombre d’éléments renvoyés par la requête." IsCompact="true">
            <ChildContent>
                <div class="backlog-metric">
                    <strong>@State.Items.Count</strong>
                    <span>éléments affichés</span>
                </div>
            </ChildContent>
        </AppCard>
    </div>

    @if (Elements.Count == 0)
    {
        <AppEmptyState Eyebrow="Backlog"
                       Title="Aucun élément ne correspond aux critères"
                       Description="Modifiez les filtres ou créez un nouvel élément pour afficher un autre scénario produit."
                       Tone="AppTone.Warning">
            <Actions>
                <AppButton Variant="AppButtonVariant.Secondary" OnClick="ReinitialiserFiltresAsync">Réinitialiser</AppButton>
                <AppButton OnClick="OuvrirCreationAsync">Créer un élément</AppButton>
            </Actions>
            <ChildContent>
                Les critères actuels ne renvoient aucun résultat. Vous pouvez élargir la recherche ou ajouter un élément à la liste.
            </ChildContent>
        </AppEmptyState>
    }
    else
    {
        <div @key="State.CurrentPage"
             class="backlog-list @ClasseAnimationPagination @(AfficherIndicateurRafraichissement ? "backlog-region--busy" : null)">
            @foreach (var item in Elements)
            {
                <div @key="item.Id" class="backlog-list__item">
                    <AppCard Title="@item.Titre"
                             Description="@item.Description"
                             Tone="@ObtenirTonalitePriorite(item.Priorite)">
                        <Actions>
                            <AppButton Variant="AppButtonVariant.Ghost" Size="AppControlSize.Small" OnClick="@((MouseEventArgs args) => OuvrirEditionAsync(item, args))">
                                Modifier
                            </AppButton>
                            <AppButton Variant="AppButtonVariant.Danger" Size="AppControlSize.Small" OnClick="@((MouseEventArgs args) => OuvrirSuppressionAsync(item, args))">
                                Supprimer
                            </AppButton>
                        </Actions>
                        <ChildContent>
                            <div class="backlog-item__meta">
                                <AppBadge Tone="@ObtenirTonaliteStatut(item.Statut)">@ObtenirLibelleStatut(item.Statut)</AppBadge>
                                <AppBadge Tone="@ObtenirTonalitePriorite(item.Priorite)">@ObtenirLibellePriorite(item.Priorite)</AppBadge>
                                <span class="backlog-item__date">Créé le @item.DateCreation.ToLocalTime().ToString("dd/MM/yyyy")</span>
                            </div>
                        </ChildContent>
                    </AppCard>
                </div>
            }
        </div>

        <div class="backlog-pagination @(AfficherIndicateurRafraichissement ? "backlog-region--busy" : null)">
            <AppButton Variant="AppButtonVariant.Secondary"
                       Size="AppControlSize.Small"
                       Disabled="@(!PeutAllerPagePrecedente || AfficherIndicateurRafraichissement)"
                       OnClick="AllerPagePrecedenteAsync">
                Page précédente
            </AppButton>

            <span class="backlog-pagination__summary">
                Page @State.CurrentPage sur @(State.TotalPages == 0 ? 1 : State.TotalPages)
            </span>

            <AppButton Variant="AppButtonVariant.Secondary"
                       Size="AppControlSize.Small"
                       Disabled="@(!PeutAllerPageSuivante || AfficherIndicateurRafraichissement)"
                       OnClick="AllerPageSuivanteAsync">
                Page suivante
            </AppButton>
        </div>
    }
}

<AppModal IsOpen="_modaleEditionOuverte"
          Title="@TitreModaleEdition"
          Description="Renseignez les informations clés pour créer ou mettre à jour un élément du backlog."
          OnClose="FermerEditionAsync">
    <ChildContent>
        <div class="backlog-form">
            <AppInput Label="Titre"
                      Placeholder="Exemple : Préparer la feuille de route Q3"
                      Required="true"
                      MaxLength="@BacklogInputRules.TitreLongueurMaximale"
                      ErrorMessage="@ObtenirErreurChamp(nameof(BacklogItemFormModel.Titre))"
                      @bind-Value="_formulaire.Titre" />

            <AppTextarea Label="Description"
                         Rows="6"
                         Required="true"
                         MaxLength="@BacklogInputRules.DescriptionLongueurMaximale"
                         Description="Une description claire facilite la lecture et la priorisation."
                         ErrorMessage="@ObtenirErreurChamp(nameof(BacklogItemFormModel.Description))"
                         @bind-Value="_formulaire.Description" />

            <div class="backlog-form__grid">
                <AppSelect Label="Statut"
                           Placeholder=""
                           Options="_statutFormulaireOptions"
                           @bind-Value="_statutFormulaireSelectionne" />

                <AppSelect Label="Priorité"
                           Placeholder=""
                           Options="_prioriteFormulaireOptions"
                           @bind-Value="_prioriteFormulaireSelectionnee" />
            </div>

            @if (!string.IsNullOrWhiteSpace(_erreurFormulaireGlobale))
            {
                <p class="backlog-form__error" role="alert">@_erreurFormulaireGlobale</p>
            }
        </div>
    </ChildContent>
    <FooterContent>
        <AppButton Variant="AppButtonVariant.Secondary" OnClick="AnnulerEditionAsync">Annuler</AppButton>
        <AppButton IsLoading="@(State.MutationStatus == BacklogRequestStatus.Loading)" OnClick="EnregistrerAsync">
            @LibelleActionEdition
        </AppButton>
    </FooterContent>
</AppModal>

<AppModal IsOpen="_modaleSuppressionOuverte"
          Title="Supprimer un élément de backlog"
          Description="Cette action retire immédiatement l’élément de la liste courante."
          OnClose="FermerSuppressionAsync">
    <ChildContent>
        <div class="backlog-delete">
            <p>
                Voulez-vous vraiment supprimer
                <strong>@(_itemEnSuppression?.Titre ?? "cet élément")</strong>
                du backlog produit ?
            </p>
        </div>
    </ChildContent>
    <FooterContent>
        <AppButton Variant="AppButtonVariant.Secondary" OnClick="AnnulerSuppressionAsync">Annuler</AppButton>
        <AppButton Variant="AppButtonVariant.Danger" IsLoading="@(State.MutationStatus == BacklogRequestStatus.Loading)" OnClick="ConfirmerSuppressionAsync">
            Supprimer
        </AppButton>
    </FooterContent>
</AppModal>
