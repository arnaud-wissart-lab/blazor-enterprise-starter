@page "/composants"

<PageTitle>Design system et composants</PageTitle>

<AppPageHeader Eyebrow="Vitrine UI"
               Title="Design system et composants applicatifs"
               Description="Cette page rassemble les fondations visuelles et les composants réutilisables du projet pour montrer une approche cohérente, sobre et directement exploitable.">
    <Badges>
        <AppBadge Tone="AppTone.Accent">Thème clair premium</AppBadge>
        <AppBadge Tone="AppTone.Success">Responsive</AppBadge>
        <AppBadge Tone="AppTone.Info">Blazor réutilisable</AppBadge>
    </Badges>
    <Actions>
        <AppButton Variant="AppButtonVariant.Secondary" Href="/">Retour à l’accueil</AppButton>
        <AppButton Href="#composants">Aller aux composants</AppButton>
    </Actions>
    <ChildContent>
        <p>
            Le design system fournit les fondations de ton, de rythme et de surfaces. La librairie de composants les
            compose ensuite pour couvrir les besoins réels d’une interface métier sans surcharger l’API des composants.
        </p>
    </ChildContent>
</AppPageHeader>

<section id="fondations" class="showcase-section">
    <div class="showcase-section__header">
        <p class="showcase-section__eyebrow">Fondations visuelles</p>
        <h3>Les partis pris de design</h3>
        <p>Une palette chaude et maîtrisée, des surfaces élégantes, une typographie lisible et un rythme d’espacements constant.</p>
    </div>

    <div class="showcase-foundation-grid">
        <AppCard Title="Palette et surfaces"
                 Description="Les couleurs privilégient la stabilité, la lisibilité et un rendu professionnel plutôt qu’un style démonstratif agressif."
                 Tone="AppTone.Accent">
            <div class="showcase-swatches">
                <div class="showcase-swatch showcase-swatch--canvas">
                    <strong>Canvas</strong>
                    <span>Fond général apaisé</span>
                </div>
                <div class="showcase-swatch showcase-swatch--surface">
                    <strong>Surface</strong>
                    <span>Cartes et panneaux</span>
                </div>
                <div class="showcase-swatch showcase-swatch--brand">
                    <strong>Accent</strong>
                    <span>Actions et focalisation</span>
                </div>
                <div class="showcase-swatch showcase-swatch--highlight">
                    <strong>Accent doux</strong>
                    <span>Relief éditorial</span>
                </div>
            </div>
        </AppCard>

        <AppCard Title="Hiérarchie typographique"
                 Description="Le projet assume une dualité entre titres éditoriaux et texte d’interface pour donner de la personnalité sans nuire à la lecture."
                 Tone="AppTone.Info">
            <div class="showcase-type-scale">
                <div>
                    <p class="showcase-type-scale__eyebrow">Eyebrow</p>
                    <span class="showcase-type-scale__meta">Repères rapides, navigation, surligne</span>
                </div>
                <div>
                    <h2>Un titre expressif pour les zones à forte valeur de démonstration</h2>
                    <span class="showcase-type-scale__meta">Titres structurants de page ou de section</span>
                </div>
                <div>
                    <p>Le texte courant reste sobre, aéré et pensé pour des contenus métier, des diagnostics ou des explications techniques.</p>
                    <span class="showcase-type-scale__meta">Texte de lecture et contenu applicatif</span>
                </div>
            </div>
        </AppCard>

        <AppCard Title="Rythme et responsive"
                 Description="L’interface repose sur quelques primitives d’espacement et de grille pour garder une maintenance simple et des transitions propres entre mobile et desktop."
                 Tone="AppTone.Success">
            <div class="showcase-rhythm">
                <div class="showcase-rhythm__bars">
                    <span></span>
                    <span></span>
                    <span></span>
                </div>
                <ul class="showcase-list">
                    <li>Espacements cohérents autour des sections, cartes et contrôles</li>
                    <li>Grilles simples qui se replient naturellement sur tablette et mobile</li>
                    <li>Priorité donnée à la lisibilité et à la compréhension des parcours</li>
                </ul>
            </div>
        </AppCard>
    </div>
</section>

<section id="composants" class="showcase-section">
    <div class="showcase-section__header">
        <p class="showcase-section__eyebrow">Composants réutilisables</p>
        <h3>Les briques prêtes à l’emploi</h3>
        <p>Les composants restent volontairement simples, typés et orientés usages concrets : actions, saisies, états et structuration de pages.</p>
    </div>

    <div class="showcase-grid">
        <AppCard Eyebrow="Actions" Title="AppButton" Description="Quatre variantes visuelles, plusieurs tailles et un état de chargement compatible avec les usages applicatifs.">
            <div class="showcase-stack">
                <div class="showcase-inline">
                    <AppButton>Action principale</AppButton>
                    <AppButton Variant="AppButtonVariant.Secondary">Secondaire</AppButton>
                    <AppButton Variant="AppButtonVariant.Ghost">Ghost</AppButton>
                    <AppButton Variant="AppButtonVariant.Danger">Danger</AppButton>
                </div>

                <div class="showcase-inline">
                    <AppButton Size="AppControlSize.Small">Petit</AppButton>
                    <AppButton Size="AppControlSize.Large">Grand</AppButton>
                    <AppButton Disabled="true">Désactivé</AppButton>
                    <AppButton Variant="AppButtonVariant.Secondary" OnClick="ToggleButtonLoadingAsync">
                        @(_isButtonLoading ? "Arrêter le chargement" : "Simuler un chargement")
                    </AppButton>
                    <AppButton IsLoading="_isButtonLoading">Action en cours</AppButton>
                </div>
            </div>
        </AppCard>

        <AppCard Eyebrow="Formulaires" Title="AppInput, AppSelect et AppTextarea" Description="Les contrôles de saisie partagent une même base de comportement et de lisibilité.">
            <div class="showcase-form-grid">
                <AppInput Label="Nom du contact"
                          Placeholder="Claire Martin"
                          Description="Signature Value / ValueChanged classique de Blazor."
                          @bind-Value="_contactName" />

                <AppInput Label="Adresse e-mail"
                          Placeholder="claire.martin@entreprise.fr"
                          InputType="AppInputType.Email"
                          ErrorMessage="@EmailError"
                          @bind-Value="_email" />

                <AppSelect Label="Environnement"
                           Description="Exemple de liste déroulante typée."
                           Options="_environments"
                           @bind-Value="_selectedEnvironment" />

                <AppTextarea Label="Message d’introduction"
                             Description="Le composant gère aussi les états d’erreur et de chargement."
                             Rows="5"
                             MaxLength="280"
                             @bind-Value="_message" />
            </div>
        </AppCard>

        <AppCard Eyebrow="Feedback" Title="AppBadge et AppLoader" Description="Des éléments légers pour signaler des statuts, des niveaux ou des attentes côté interface.">
            <div class="showcase-stack">
                <div class="showcase-inline">
                    <AppBadge Tone="AppTone.Neutral">Brouillon</AppBadge>
                    <AppBadge Tone="AppTone.Accent">En cours</AppBadge>
                    <AppBadge Tone="AppTone.Success">Conforme</AppBadge>
                    <AppBadge Tone="AppTone.Warning">À vérifier</AppBadge>
                    <AppBadge Tone="AppTone.Danger">Bloqué</AppBadge>
                </div>

                <div class="showcase-inline">
                    <AppLoader Label="Synchronisation" />
                    <AppLoader Size="AppControlSize.Small" Label="Chargement léger" />
                    <AppLoader Size="AppControlSize.Large" Label="Traitement étendu" />
                </div>
            </div>
        </AppCard>

        <AppCard Eyebrow="Composition" Title="AppCard et AppPageHeader" Description="Des briques de composition pour construire des pages métier avec une hiérarchie visuelle stable.">
            <div class="showcase-stack">
                <AppPageHeader Title="Tableau de bord régional"
                               Description="Exemple d’en-tête interne réutilisable pour une page métier ou un onglet fonctionnel."
                               Class="showcase-nested-header">
                    <Badges>
                        <AppBadge Tone="AppTone.Success">Synchronisé</AppBadge>
                    </Badges>
                    <Actions>
                        <AppButton Variant="AppButtonVariant.Secondary" Size="AppControlSize.Small">Exporter</AppButton>
                        <AppButton Size="AppControlSize.Small">Créer</AppButton>
                    </Actions>
                </AppPageHeader>

                <AppCard Title="Carte imbriquée" Description="Une carte peut encapsuler des sous-sections ou des métriques sans rompre la cohérence générale." IsCompact="true">
                    <div class="showcase-metrics">
                        <div>
                            <strong>98,4 %</strong>
                            <span>Taux de disponibilité</span>
                        </div>
                        <div>
                            <strong>24 min</strong>
                            <span>Délai moyen de traitement</span>
                        </div>
                        <div>
                            <strong>12</strong>
                            <span>Alertes ouvertes</span>
                        </div>
                    </div>
                </AppCard>
            </div>
        </AppCard>

        <AppCard Eyebrow="États" Title="AppEmptyState et AppModal" Description="Des composants pensés pour les situations fréquentes : absence de données et confirmation d’action.">
            <div class="showcase-stack">
                <AppEmptyState Eyebrow="Données"
                               Title="Aucun rapport n’est encore disponible"
                               Description="Le composant évite les écrans vides et oriente immédiatement l’utilisateur vers l’action utile."
                               Tone="AppTone.Accent">
                    <VisualContent>
                        <span class="showcase-visual-token">0</span>
                    </VisualContent>
                    <Actions>
                        <AppButton Size="AppControlSize.Small">Créer un premier rapport</AppButton>
                        <AppButton Variant="AppButtonVariant.Secondary" Size="AppControlSize.Small">Importer</AppButton>
                    </Actions>
                    <ChildContent>
                        Les actions restent pilotées par l’écran appelant, sans logique métier dans le composant.
                    </ChildContent>
                </AppEmptyState>

                <div class="showcase-inline">
                    <AppButton Variant="AppButtonVariant.Secondary" OnClick="OpenModalAsync">Ouvrir la modale</AppButton>
                </div>
            </div>
        </AppCard>
    </div>
</section>

<AppModal IsOpen="_isModalOpen"
          Title="Exemple de modale"
          Description="La modale reste simple : contenu court, fermeture explicite et gestion basique d’Échap et du clic de fond."
          OnClose="CloseModalAsync">
    <ChildContent>
        <div class="showcase-modal-copy">
            <p>
                Cette implémentation vise un usage pragmatique pour des confirmations, des aides contextuelles
                ou des formulaires brefs. Elle n’embarque pas encore de piège de focus avancé.
            </p>
            <p>
                Ce choix garde le composant lisible et maintenable tout en posant une base saine pour un raffinement ultérieur.
            </p>
        </div>
    </ChildContent>
    <FooterContent>
        <AppButton Variant="AppButtonVariant.Secondary" OnClick="CloseFromButtonAsync">Annuler</AppButton>
        <AppButton OnClick="ConfirmModalAsync">Confirmer</AppButton>
    </FooterContent>
</AppModal>

@code {
    private readonly IReadOnlyList<AppSelectOption> _environments =
    [
        new("local", "Local"),
        new("integration", "Intégration"),
        new("production", "Production")
    ];

    private string? _contactName = "Claire Martin";
    private string? _email = "claire.martin@entreprise.fr";
    private string? _selectedEnvironment = "integration";
    private string? _message = "Bonjour, nous préparons la démonstration du socle applicatif et du design system.";
    private bool _isButtonLoading;
    private bool _isModalOpen;

    private string? EmailError =>
        string.IsNullOrWhiteSpace(_email) || _email.Contains('@', StringComparison.Ordinal)
            ? null
            : "Le format de l’adresse e-mail semble incorrect.";

    private Task ToggleButtonLoadingAsync(MouseEventArgs _)
    {
        _isButtonLoading = !_isButtonLoading;
        return Task.CompletedTask;
    }

    private Task OpenModalAsync(MouseEventArgs _)
    {
        _isModalOpen = true;
        return Task.CompletedTask;
    }

    private Task CloseFromButtonAsync(MouseEventArgs _)
    {
        _isModalOpen = false;
        return Task.CompletedTask;
    }

    private Task ConfirmModalAsync(MouseEventArgs _)
    {
        _isModalOpen = false;
        return Task.CompletedTask;
    }

    private Task CloseModalAsync()
    {
        _isModalOpen = false;
        return Task.CompletedTask;
    }
}
