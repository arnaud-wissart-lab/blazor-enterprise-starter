@page "/composants"

<PageTitle>Design system et composants</PageTitle>

<AppPageHeader Eyebrow="Bibliothèque UI"
               Title="Design system et composants"
               Description="Cette page sert de référence visuelle pour les styles globaux, les composants réutilisables et leurs états principaux.">
    <Badges>
        <AppBadge Tone="AppTone.Accent">Tokens CSS</AppBadge>
        <AppBadge Tone="AppTone.Info">Composants Blazor</AppBadge>
        <AppBadge Tone="AppTone.Neutral">Interactive Server</AppBadge>
        <AppBadge Tone="AppTone.Success">Responsive</AppBadge>
    </Badges>
    <Actions>
        <AppButton Variant="AppButtonVariant.Secondary" Href="/">Retour à l’accueil</AppButton>
        <AppButton Href="/backlog">Voir le backlog</AppButton>
    </Actions>
    <ChildContent>
        <p>La navigation latérale permet de revenir facilement au parcours principal à tout moment.</p>
    </ChildContent>
</AppPageHeader>

<section id="blazor" class="showcase-section">
    <div class="showcase-section__header">
        <p class="showcase-section__eyebrow">Choix Blazor</p>
        <h3>Ce que la vitrine assume côté front</h3>
        <p>Le projet cherche à montrer un usage crédible de Blazor sur un front métier, pas à accumuler tous les modes de rendu ou toutes les abstractions possibles.</p>
    </div>

    <div class="showcase-blazor-grid">
        <AppCard Title="Mode de rendu choisi"
                 Description="La démonstration repose sur une Blazor Web App en mode Interactive Server."
                 Tone="AppTone.Accent"
                 IsCompact="true">
            <ChildContent>
                <p>Ce choix rend visibles la composition Razor, l’interactivité et l’intégration avec le backend sans transformer la vitrine en laboratoire technique difficile à lire.</p>
            </ChildContent>
            <Footer>
                <div class="showcase-inline">
                    <AppBadge Tone="AppTone.Accent">AddInteractiveServerComponents</AppBadge>
                    <AppBadge Tone="AppTone.Info">AddInteractiveServerRenderMode</AppBadge>
                </div>
            </Footer>
        </AppCard>

        <AppCard Title="Ce que Blazor démontre ici"
                 Description="Les composants Razor sont utilisés comme briques de composition et d’interaction."
                 Tone="AppTone.Info"
                 IsCompact="true">
            <ChildContent>
                <ul class="showcase-list">
                    <li>composition du shell, des pages et des composants réutilisables</li>
                    <li>binding et événements utilisateurs sur boutons, champs et modales</li>
                    <li>état local explicite pour le module backlog et appels HTTP dédiés</li>
                </ul>
            </ChildContent>
        </AppCard>

        <AppCard Title="Compromis assumés"
                 Description="Le dépôt ne cherche pas à démontrer tous les scénarios Blazor à la fois."
                 Tone="AppTone.Success"
                 IsCompact="true">
            <ChildContent>
                <p>Le projet n’a pas pour but principal de montrer WebAssembly, un store client global complexe ou une combinatoire complète de modes de rendu. Il privilégie la lisibilité, la cohérence et la démonstration métier.</p>
            </ChildContent>
            <Footer>
                <div class="showcase-inline">
                    <AppBadge Tone="AppTone.Neutral">Lisibilité</AppBadge>
                    <AppBadge Tone="AppTone.Success">Architecture front</AppBadge>
                    <AppBadge Tone="AppTone.Warning">Compromis documentés</AppBadge>
                </div>
            </Footer>
        </AppCard>
    </div>
</section>

<section id="fondations" class="showcase-section">
    <div class="showcase-section__header">
        <p class="showcase-section__eyebrow">Fondations visuelles</p>
        <h3>Les bases du langage visuel</h3>
        <p>Les fondations privilégient la lisibilité, la hiérarchie et la stabilité plutôt qu’un habillage démonstratif.</p>
    </div>

    <div class="showcase-foundation-grid">
        <AppCard Title="Palette et surfaces"
                 Description="La palette s’appuie sur des neutres froids et un accent principal unique pour garder des écrans lisibles."
                 Tone="AppTone.Accent">
            <div class="showcase-swatches">
                <div class="showcase-swatch showcase-swatch--canvas">
                    <strong>Fond</strong>
                    <span>Arrière-plan principal</span>
                </div>
                <div class="showcase-swatch showcase-swatch--surface">
                    <strong>Surface</strong>
                    <span>Cartes et panneaux</span>
                </div>
                <div class="showcase-swatch showcase-swatch--brand">
                    <strong>Accent principal</strong>
                    <span>Actions et navigation active</span>
                </div>
                <div class="showcase-swatch showcase-swatch--highlight">
                    <strong>Accent secondaire</strong>
                    <span>Indicateurs complémentaires</span>
                </div>
            </div>
        </AppCard>

        <AppCard Title="Hiérarchie typographique"
                 Description="Les tailles et les contrastes sont calibrés pour des écrans de travail et des captures de projet."
                 Tone="AppTone.Info">
            <div class="showcase-type-scale">
                <div>
                    <p class="showcase-type-scale__eyebrow">Eyebrow</p>
                    <span class="showcase-type-scale__meta">Repères de section et de navigation</span>
                </div>
                <div>
                    <h2>Un titre net pour annoncer clairement la section affichée</h2>
                    <span class="showcase-type-scale__meta">Titres de page, cartes importantes et panneaux</span>
                </div>
                <div>
                    <p>Le texte courant reste compact et lisible pour des filtres, des formulaires, des résumés et des écrans métier.</p>
                    <span class="showcase-type-scale__meta">Texte descriptif et contenu applicatif</span>
                </div>
            </div>
        </AppCard>

        <AppCard Title="Rythme et responsive"
                 Description="Les grilles et espacements sont limités à quelques règles simples pour conserver une maintenance directe."
                 Tone="AppTone.Success">
            <div class="showcase-rhythm">
                <div class="showcase-rhythm__bars">
                    <span></span>
                    <span></span>
                    <span></span>
                </div>
                <ul class="showcase-list">
                    <li>Espacements réguliers autour des sections, cartes et contrôles</li>
                    <li>Repli simple des grilles sur tablette et mobile</li>
                    <li>Navigation et titres conçus pour rester compréhensibles sur chaque format</li>
                </ul>
            </div>
        </AppCard>
    </div>
</section>

<section id="composants" class="showcase-section">
    <div class="showcase-section__header">
        <p class="showcase-section__eyebrow">Composants réutilisables</p>
        <h3>Les briques prêtes à l’emploi</h3>
        <p>Les composants privilégient une API simple, des états explicites et des usages directement réemployables dans une interface métier.</p>
    </div>

    <div class="showcase-grid">
        <AppCard Eyebrow="Actions" Title="AppButton" Description="Variantes principales, tailles et état de chargement pour les actions d’écran.">
            <div class="showcase-stack">
                <div class="showcase-inline">
                    <AppButton OnClick="MontrerActionPrincipaleAsync">Action principale</AppButton>
                    <AppButton Variant="AppButtonVariant.Secondary" OnClick="MontrerActionSecondaireAsync">Secondaire</AppButton>
                    <AppButton Variant="AppButtonVariant.Ghost" OnClick="MontrerActionNavigationAsync">Ghost</AppButton>
                    <AppButton Variant="AppButtonVariant.Danger" OnClick="MontrerActionDangerAsync">Danger</AppButton>
                </div>

                <div class="showcase-inline">
                    <AppButton Size="AppControlSize.Small" OnClick="MontrerActionPetiteAsync">Petit</AppButton>
                    <AppButton Size="AppControlSize.Large" OnClick="MontrerActionGrandeAsync">Grand</AppButton>
                    <AppButton Disabled="true">Désactivé</AppButton>
                    <AppButton Variant="AppButtonVariant.Secondary" OnClick="ToggleButtonLoadingAsync">
                        @(_isButtonLoading ? "Désactiver l’état de chargement" : "Activer l’état de chargement")
                    </AppButton>
                    <AppButton IsLoading="_isButtonLoading">Action en cours</AppButton>
                </div>

                @if (!string.IsNullOrWhiteSpace(_messageInteraction))
                {
                    <p class="showcase-feedback" role="status">@_messageInteraction</p>
                }
            </div>
        </AppCard>

        <AppCard Eyebrow="Formulaires" Title="AppInput, AppSelect et AppTextarea" Description="Les champs partagent les mêmes conventions de lisibilité, de validation et de focus.">
            <div class="showcase-form-grid">
                <AppInput Label="Nom du contact"
                          Placeholder="Claire Martin"
                          Description="Binding simple et intégration naturelle dans un formulaire Blazor."
                          @bind-Value="_contactName" />

                <AppInput Label="Adresse e-mail"
                          Placeholder="claire.martin@entreprise.fr"
                          InputType="AppInputType.Email"
                          ErrorMessage="@EmailError"
                          @bind-Value="_email" />

                <AppSelect Label="Environnement"
                           Description="Exemple de liste déroulante typée."
                           Options="_environments"
                           @bind-Value="_selectedEnvironment" />

                <AppTextarea Label="Message d’introduction"
                             Description="Le composant gère aussi les états d’erreur et de chargement."
                             Rows="5"
                             MaxLength="280"
                             @bind-Value="_message" />
            </div>
            <p class="showcase-form-note">
                Les exemples ci-dessus servent à vérifier le rythme vertical, la validation et la cohérence des états de focus.
            </p>
        </AppCard>

        <AppCard Eyebrow="Feedback" Title="AppBadge et AppLoader" Description="Des éléments légers pour signaler des statuts, des niveaux ou une attente côté interface.">
            <div class="showcase-stack">
                <div class="showcase-inline">
                    <AppBadge Tone="AppTone.Neutral">Brouillon</AppBadge>
                    <AppBadge Tone="AppTone.Accent">En cours</AppBadge>
                    <AppBadge Tone="AppTone.Success">Conforme</AppBadge>
                    <AppBadge Tone="AppTone.Warning">À vérifier</AppBadge>
                    <AppBadge Tone="AppTone.Danger">Bloqué</AppBadge>
                </div>

                <div class="showcase-inline">
                    <AppLoader Label="Synchronisation" />
                    <AppLoader Size="AppControlSize.Small" Label="Chargement léger" />
                    <AppLoader Size="AppControlSize.Large" Label="Traitement étendu" />
                </div>
            </div>
        </AppCard>

        <AppCard Eyebrow="Composition" Title="AppCard et AppPageHeader" Description="Des briques de composition pour construire des écrans métier avec une hiérarchie stable.">
            <div class="showcase-stack">
                <AppPageHeader Title="Tableau de bord régional"
                               Description="Exemple d’en-tête réutilisable pour une page métier ou un onglet fonctionnel."
                               Class="showcase-nested-header">
                    <Badges>
                        <AppBadge Tone="AppTone.Success">Synchronisé</AppBadge>
                    </Badges>
                    <Actions>
                        <AppButton Variant="AppButtonVariant.Secondary" Size="AppControlSize.Small" OnClick="ExporterExempleAsync">Exporter</AppButton>
                        <AppButton Size="AppControlSize.Small" OnClick="CreerExempleAsync">Créer</AppButton>
                    </Actions>
                </AppPageHeader>

                <AppCard Title="Carte imbriquée" Description="Une carte peut encapsuler des sous-sections ou des métriques sans rompre la cohérence générale." IsCompact="true">
                    <div class="showcase-metrics">
                        <div>
                            <strong>98,4 %</strong>
                            <span>Taux de disponibilité</span>
                        </div>
                        <div>
                            <strong>24 min</strong>
                            <span>Délai moyen de traitement</span>
                        </div>
                        <div>
                            <strong>12</strong>
                            <span>Alertes ouvertes</span>
                        </div>
                    </div>
                </AppCard>
            </div>
        </AppCard>

        <AppCard Eyebrow="États" Title="AppEmptyState et AppModal" Description="Des composants pensés pour l’absence de données et les confirmations courtes.">
            <div class="showcase-stack">
                <AppEmptyState Eyebrow="Données"
                               Title="Aucun rapport n’est encore disponible"
                               Description="Le composant évite les écrans vides et oriente immédiatement l’utilisateur vers l’action utile."
                               Tone="AppTone.Accent">
                    <VisualContent>
                        <span class="showcase-visual-token">0</span>
                    </VisualContent>
                    <Actions>
                        <AppButton Size="AppControlSize.Small" OnClick="CreerRapportExempleAsync">Créer un premier rapport</AppButton>
                        <AppButton Variant="AppButtonVariant.Secondary" Size="AppControlSize.Small" OnClick="ImporterRapportExempleAsync">Importer</AppButton>
                    </Actions>
                    <ChildContent>
                        Dans cette démonstration, les actions déclenchent une modale ou un message de confirmation pour illustrer le comportement attendu.
                    </ChildContent>
                </AppEmptyState>

                <div class="showcase-inline">
                    <AppButton Variant="AppButtonVariant.Secondary" OnClick="OpenModalAsync">Ouvrir la modale</AppButton>
                </div>
            </div>
        </AppCard>
    </div>
</section>

<AppModal IsOpen="_isModalOpen"
          Title="@_titreModale"
          Description="@_descriptionModale"
          OnClose="CloseModalAsync">
    <ChildContent>
        <div class="showcase-modal-copy">
            <p>@_contenuModale</p>
            <p>Le contenu reste volontairement bref pour préserver la lisibilité et mettre l’action principale au premier plan.</p>
        </div>
    </ChildContent>
    <FooterContent>
        <AppButton Variant="AppButtonVariant.Secondary" OnClick="CloseFromButtonAsync">Annuler</AppButton>
        <AppButton OnClick="ConfirmModalAsync">Confirmer</AppButton>
    </FooterContent>
</AppModal>

@code {
    private readonly IReadOnlyList<AppSelectOption> _environments =
    [
        new("local", "Local"),
        new("integration", "Intégration"),
        new("production", "Production")
    ];

    private string? _contactName = "Claire Martin";
    private string? _email = "claire.martin@entreprise.fr";
    private string? _selectedEnvironment = "integration";
    private string? _message = "Bonjour, je vous partage un premier aperçu du tableau de bord produit.";
    private bool _isButtonLoading;
    private bool _isModalOpen;
    private string? _messageInteraction;
    private string _titreModale = "Exemple de modale";
    private string _descriptionModale = "La modale illustre un dialogue court, lisible et centré sur une action explicite.";
    private string _contenuModale = "Ce format fonctionne bien pour une confirmation, une action secondaire ou un court complément d’information.";

    private string? EmailError =>
        string.IsNullOrWhiteSpace(_email) || _email.Contains('@', StringComparison.Ordinal)
            ? null
            : "Le format de l’adresse e-mail semble incorrect.";

    private Task ToggleButtonLoadingAsync(MouseEventArgs _)
    {
        _isButtonLoading = !_isButtonLoading;
        _messageInteraction = _isButtonLoading
            ? "L’état de chargement est activé sur le bouton de démonstration."
            : "L’état de chargement est désactivé.";
        return Task.CompletedTask;
    }

    private Task MontrerActionPrincipaleAsync(MouseEventArgs _)
    {
        _messageInteraction = "Action principale déclenchée : en situation réelle, elle lancerait l’opération prioritaire de l’écran.";
        return Task.CompletedTask;
    }

    private Task MontrerActionSecondaireAsync(MouseEventArgs _)
    {
        _messageInteraction = "Action secondaire déclenchée : elle illustre une action utile mais non prioritaire.";
        return Task.CompletedTask;
    }

    private Task MontrerActionNavigationAsync(MouseEventArgs _)
    {
        _messageInteraction = "Action de navigation déclenchée : la variante ghost reste adaptée aux actions discrètes.";
        return Task.CompletedTask;
    }

    private Task MontrerActionDangerAsync(MouseEventArgs _)
    {
        _messageInteraction = "Action sensible déclenchée : la variante danger sert à signaler un impact potentiellement destructif.";
        return Task.CompletedTask;
    }

    private Task MontrerActionPetiteAsync(MouseEventArgs _)
    {
        _messageInteraction = "Le format compact convient aux tableaux, listes denses et zones d’actions secondaires.";
        return Task.CompletedTask;
    }

    private Task MontrerActionGrandeAsync(MouseEventArgs _)
    {
        _messageInteraction = "Le format large sert à renforcer une action importante dans un contexte éditorial ou un pied de page.";
        return Task.CompletedTask;
    }

    private Task ExporterExempleAsync(MouseEventArgs _)
    {
        _messageInteraction = "Export déclenché : dans un écran réel, cette action préparerait un fichier ou un rapport.";
        return Task.CompletedTask;
    }

    private Task CreerExempleAsync(MouseEventArgs _)
    {
        ConfigurerModale(
            "Créer un élément",
            "Exemple d’action primaire associée à un en-tête de page.",
            "Dans un écran métier, cette action ouvrirait le formulaire de création ou la vue dédiée.");

        return Task.CompletedTask;
    }

    private Task CreerRapportExempleAsync(MouseEventArgs _)
    {
        ConfigurerModale(
            "Créer un premier rapport",
            "Exemple d’action principale sur un état vide.",
            "Le composant peut orienter vers la prochaine étape utile, ici l’ouverture d’un flux de création.");

        return Task.CompletedTask;
    }

    private Task ImporterRapportExempleAsync(MouseEventArgs _)
    {
        _messageInteraction = "Import déclenché : dans un écran réel, cette action ouvrirait un assistant ou un sélecteur de fichier.";
        return Task.CompletedTask;
    }

    private Task OpenModalAsync(MouseEventArgs _)
    {
        ConfigurerModale(
            "Exemple de modale",
            "La modale illustre un dialogue court, lisible et centré sur une action explicite.",
            "Ce format fonctionne bien pour une confirmation, une action secondaire ou un court complément d’information.");

        return Task.CompletedTask;
    }

    private Task CloseFromButtonAsync(MouseEventArgs _)
    {
        _isModalOpen = false;
        return Task.CompletedTask;
    }

    private Task ConfirmModalAsync(MouseEventArgs _)
    {
        _isModalOpen = false;
        _messageInteraction = "La confirmation a été prise en compte sur l’exemple de modale.";
        return Task.CompletedTask;
    }

    private Task CloseModalAsync()
    {
        _isModalOpen = false;
        return Task.CompletedTask;
    }

    private void ConfigurerModale(string titre, string description, string contenu)
    {
        _titreModale = titre;
        _descriptionModale = description;
        _contenuModale = contenu;
        _isModalOpen = true;
    }
}
