@page "/composants"

<PageTitle>Bibliothèque UI</PageTitle>

<AppPageHeader Eyebrow="Bibliothèque UI"
               Title="Bibliothèque UI"
               Description="Référence visuelle des fondations, composants et états utilisés dans le starter.">
    <Badges>
        <AppBadge Tone="AppTone.Accent">Tokens CSS</AppBadge>
        <AppBadge Tone="AppTone.Info">Composants Blazor</AppBadge>
        <AppBadge Tone="AppTone.Success">États d’interface</AppBadge>
        <AppBadge Tone="AppTone.Neutral">Responsive</AppBadge>
    </Badges>
    <Actions>
        <AppButton Variant="AppButtonVariant.Secondary" Href="/">Retour à l’accueil</AppButton>
        <AppButton Href="/backlog">Voir le backlog</AppButton>
    </Actions>
    <ChildContent>
        <p class="showcase-page-note">Les composants sont montrés dans leurs variantes utiles. Le commentaire reste volontairement court.</p>
    </ChildContent>
</AppPageHeader>

<section class="showcase-section" id="fondations">
    <div class="showcase-section__header">
        <p class="showcase-section__eyebrow">Fondations</p>
        <h2>Les règles de base du système</h2>
        <p>Les fondations assurent une interface stable, lisible et facile à reprendre dans une application métier.</p>
    </div>

    <div class="showcase-grid showcase-grid--three">
        <AppCard Title="Palette et surfaces"
                 Description="Un fond sobre, des surfaces nettes et un accent principal unique."
                 Tone="AppTone.Accent">
            <div class="showcase-swatches">
                <div class="showcase-swatch showcase-swatch--canvas">
                    <strong>Fond</strong>
                    <span>Arrière-plan principal</span>
                </div>
                <div class="showcase-swatch showcase-swatch--surface">
                    <strong>Surface</strong>
                    <span>Cartes et panneaux</span>
                </div>
                <div class="showcase-swatch showcase-swatch--brand">
                    <strong>Accent principal</strong>
                    <span>Actions et navigation active</span>
                </div>
                <div class="showcase-swatch showcase-swatch--highlight">
                    <strong>Accent secondaire</strong>
                    <span>Indicateurs complémentaires</span>
                </div>
            </div>
        </AppCard>

        <AppCard Title="Hiérarchie typographique"
                 Description="Une échelle pensée pour le scan rapide d’une interface de travail."
                 Tone="AppTone.Info">
            <div class="showcase-type-scale">
                <div>
                    <p class="showcase-type-scale__eyebrow">Eyebrow</p>
                    <span class="showcase-type-scale__meta">Repères de page, de section et de navigation</span>
                </div>
                <div>
                    <h2>Un titre net pour annoncer clairement une zone importante</h2>
                    <span class="showcase-type-scale__meta">Titres de page, cartes principales et panneaux structurants</span>
                </div>
                <div>
                    <p>Le texte courant reste volontairement compact pour préserver la densité et la lisibilité.</p>
                    <span class="showcase-type-scale__meta">Descriptions, aides et contenus métier</span>
                </div>
            </div>
        </AppCard>

        <AppCard Title="Rythme et responsive"
                 Description="Quelques règles simples pour garder un rendu stable sur desktop, tablette et mobile."
                 Tone="AppTone.Success">
            <div class="showcase-rhythm">
                <div class="showcase-rhythm__diagram" aria-hidden="true">
                    <div class="showcase-rhythm__frame">
                        <span class="showcase-rhythm__label">Desktop</span>
                        <div class="showcase-rhythm__rows">
                            <span class="showcase-rhythm__row showcase-rhythm__row--wide"></span>
                            <span class="showcase-rhythm__row showcase-rhythm__row--split"></span>
                            <span class="showcase-rhythm__row showcase-rhythm__row--split"></span>
                        </div>
                    </div>
                    <div class="showcase-rhythm__frame">
                        <span class="showcase-rhythm__label">Tablette</span>
                        <div class="showcase-rhythm__rows">
                            <span class="showcase-rhythm__row showcase-rhythm__row--wide"></span>
                            <span class="showcase-rhythm__row showcase-rhythm__row--medium"></span>
                            <span class="showcase-rhythm__row showcase-rhythm__row--medium"></span>
                        </div>
                    </div>
                    <div class="showcase-rhythm__frame">
                        <span class="showcase-rhythm__label">Mobile</span>
                        <div class="showcase-rhythm__rows">
                            <span class="showcase-rhythm__row showcase-rhythm__row--wide"></span>
                            <span class="showcase-rhythm__row showcase-rhythm__row--wide"></span>
                            <span class="showcase-rhythm__row showcase-rhythm__row--wide"></span>
                        </div>
                    </div>
                </div>
                <ul class="showcase-list">
                    <li>espacements constants entre sections, cartes et contrôles</li>
                    <li>grilles qui se replient sans changer la logique de lecture</li>
                    <li>densité raisonnable pour une interface de travail</li>
                </ul>
            </div>
        </AppCard>
    </div>
</section>

<section class="showcase-section" id="actions">
    <div class="showcase-section__header">
        <p class="showcase-section__eyebrow">Actions et saisie</p>
        <h2>Les composants utilisés au quotidien</h2>
        <p>Actions, champs et sélecteurs partagent les mêmes conventions de taille, de focus et de densité.</p>
    </div>

    <div class="showcase-grid showcase-grid--two">
        <AppCard Eyebrow="Actions"
                 Title="AppButton"
                 Description="Variantes principales, tailles et état de chargement."
                 Tone="AppTone.Accent">
            <div class="showcase-stack">
                <div class="showcase-inline">
                    <AppButton OnClick="MontrerActionPrincipaleAsync">Principale</AppButton>
                    <AppButton Variant="AppButtonVariant.Secondary" OnClick="MontrerActionSecondaireAsync">Secondaire</AppButton>
                    <AppButton Variant="AppButtonVariant.Ghost" OnClick="MontrerActionNavigationAsync">Ghost</AppButton>
                    <AppButton Variant="AppButtonVariant.Danger" OnClick="MontrerActionDangerAsync">Danger</AppButton>
                </div>

                <div class="showcase-inline">
                    <AppButton Size="AppControlSize.Small" OnClick="MontrerActionPetiteAsync">Petit</AppButton>
                    <AppButton Size="AppControlSize.Large" OnClick="MontrerActionGrandeAsync">Grand</AppButton>
                    <AppButton Disabled="true">Désactivé</AppButton>
                    <AppButton Variant="AppButtonVariant.Secondary" OnClick="ToggleButtonLoadingAsync">
                        @(_isButtonLoading ? "Désactiver le chargement" : "Activer le chargement")
                    </AppButton>
                    <AppButton IsLoading="_isButtonLoading">Action en cours</AppButton>
                </div>

                @if (!string.IsNullOrWhiteSpace(_messageInteraction))
                {
                    <p class="showcase-feedback" role="status">@_messageInteraction</p>
                }
            </div>
        </AppCard>

        <AppCard Eyebrow="Saisie"
                 Title="AppInput, AppSelect et AppTextarea"
                 Description="Les champs restent lisibles et homogènes, sans variantes inutiles."
                 Tone="AppTone.Info">
            <div class="showcase-form-grid">
                <AppInput Label="Nom du contact"
                          Placeholder="Claire Martin"
                          Description="Exemple de champ texte standard."
                          @bind-Value="_contactName" />

                <AppInput Label="Adresse e-mail"
                          Placeholder="claire.martin@entreprise.fr"
                          InputType="AppInputType.Email"
                          ErrorMessage="@EmailError"
                          @bind-Value="_email" />

                <AppSelect Label="Environnement"
                           Description="Liste déroulante typée."
                           Options="_environments"
                           @bind-Value="_selectedEnvironment" />

                <AppTextarea Label="Message"
                             Description="Champ multi-ligne avec limite visible."
                             Rows="5"
                             MaxLength="280"
                             @bind-Value="_message" />
            </div>
        </AppCard>
    </div>
</section>

<section class="showcase-section" id="feedback">
    <div class="showcase-section__header">
        <p class="showcase-section__eyebrow">Statuts et feedback</p>
        <h2>Informer sans surcharger l’interface</h2>
        <p>Badges, loaders et messages signalent un état, une priorité ou une attente sans casser la lecture.</p>
    </div>

    <div class="showcase-grid showcase-grid--two">
        <AppCard Eyebrow="Statuts"
                 Title="AppBadge"
                 Description="Une échelle simple pour représenter l’état et la criticité."
                 Tone="AppTone.Success">
            <div class="showcase-stack">
                <div class="showcase-inline">
                    <AppBadge Tone="AppTone.Neutral">Brouillon</AppBadge>
                    <AppBadge Tone="AppTone.Accent">En cours</AppBadge>
                    <AppBadge Tone="AppTone.Success">Conforme</AppBadge>
                    <AppBadge Tone="AppTone.Warning">À vérifier</AppBadge>
                    <AppBadge Tone="AppTone.Danger">Bloqué</AppBadge>
                </div>
                <p class="showcase-feedback">Les couleurs suivent une logique sémantique stable entre la vitrine et le backlog.</p>
            </div>
        </AppCard>

        <AppCard Eyebrow="Chargement"
                 Title="AppLoader"
                 Description="Une attente visible mais discrète, adaptée au contexte."
                 Tone="AppTone.Warning">
            <div class="showcase-stack">
                <div class="showcase-inline showcase-inline--loaders">
                    <AppLoader Size="AppControlSize.Small" Label="Léger" />
                    <AppLoader Label="Standard" />
                    <AppLoader Size="AppControlSize.Large" Label="Étendu" />
                </div>
                <p class="showcase-feedback">Les trois tailles sont volontairement distinguées pour qu’une équipe puisse les utiliser selon la densité de l’écran.</p>
            </div>
        </AppCard>
    </div>
</section>

<section class="showcase-section" id="composition">
    <div class="showcase-section__header">
        <p class="showcase-section__eyebrow">Composition d’écran</p>
        <h2>Assembler des écrans métier cohérents</h2>
        <p>Les composants de structure composent une page complète sans rompre la hiérarchie visuelle du système.</p>
    </div>

    <div class="showcase-grid showcase-grid--two">
        <AppCard Eyebrow="Structure"
                 Title="AppPageHeader et cartes"
                 Description="Un en-tête réutilisable pour les pages, suivi de cartes plus compactes pour le détail."
                 Tone="AppTone.Accent">
            <div class="showcase-stack">
                <AppPageHeader Title="Tableau de bord régional"
                               Description="Exemple d’en-tête réutilisable pour une page métier ou un onglet fonctionnel."
                               Class="showcase-nested-header">
                    <Badges>
                        <AppBadge Tone="AppTone.Success">Synchronisé</AppBadge>
                    </Badges>
                    <Actions>
                        <AppButton Variant="AppButtonVariant.Secondary" Size="AppControlSize.Small" OnClick="ExporterExempleAsync">Exporter</AppButton>
                        <AppButton Size="AppControlSize.Small" OnClick="CreerExempleAsync">Créer</AppButton>
                    </Actions>
                </AppPageHeader>

                <AppCard Title="Carte imbriquée"
                         Description="Une carte secondaire peut détailler métriques, sous-sections ou indicateurs."
                         IsCompact="true">
                    <div class="showcase-metrics">
                        <div>
                            <strong>98,4 %</strong>
                            <span>Taux de disponibilité</span>
                        </div>
                        <div>
                            <strong>24 min</strong>
                            <span>Délai moyen</span>
                        </div>
                        <div>
                            <strong>12</strong>
                            <span>Alertes ouvertes</span>
                        </div>
                    </div>
                </AppCard>
            </div>
        </AppCard>

        <AppCard Eyebrow="États"
                 Title="AppEmptyState et AppModal"
                 Description="Des composants conçus pour l’absence de données et les confirmations courtes."
                 Tone="AppTone.Info">
            <div class="showcase-stack">
                <AppEmptyState Eyebrow="Données"
                               Title="Aucun rapport n’est encore disponible"
                               Description="Le composant évite les écrans vides et oriente immédiatement vers l’action utile."
                               Tone="AppTone.Accent">
                    <VisualContent>
                        <span class="showcase-visual-token">0</span>
                    </VisualContent>
                    <Actions>
                        <AppButton Size="AppControlSize.Small" OnClick="CreerRapportExempleAsync">Créer un premier rapport</AppButton>
                        <AppButton Variant="AppButtonVariant.Secondary" Size="AppControlSize.Small" OnClick="ImporterRapportExempleAsync">Importer</AppButton>
                    </Actions>
                    <ChildContent>
                        L’état vide reste démonstratif sans être bavard, avec une action principale claire et une alternative secondaire.
                    </ChildContent>
                </AppEmptyState>
            </div>
        </AppCard>
    </div>
</section>

<AppModal IsOpen="_isModalOpen"
          Title="@_titreModale"
          Description="@_descriptionModale"
          OnClose="CloseModalAsync">
    <ChildContent>
        <div class="showcase-modal-copy">
            <p>@_contenuModale</p>
            <p>Le contenu reste volontairement bref pour préserver la lisibilité et mettre l’action principale au premier plan.</p>
        </div>
    </ChildContent>
    <FooterContent>
        <AppButton Variant="AppButtonVariant.Secondary" OnClick="CloseFromButtonAsync">Annuler</AppButton>
        <AppButton OnClick="ConfirmModalAsync">Confirmer</AppButton>
    </FooterContent>
</AppModal>

@code {
    private readonly IReadOnlyList<AppSelectOption> _environments =
    [
        new("local", "Local"),
        new("integration", "Intégration"),
        new("production", "Production")
    ];

    private string? _contactName = "Claire Martin";
    private string? _email = "claire.martin@entreprise.fr";
    private string? _selectedEnvironment = "integration";
    private string? _message = "Bonjour, je vous partage un premier aperçu du tableau de bord produit.";
    private bool _isButtonLoading;
    private bool _isModalOpen;
    private string? _messageInteraction;
    private string _titreModale = "Exemple de modale";
    private string _descriptionModale = "La modale illustre un dialogue court, lisible et centré sur une action explicite.";
    private string _contenuModale = "Ce format fonctionne bien pour une confirmation, une action secondaire ou un court complément d’information.";

    private string? EmailError =>
        string.IsNullOrWhiteSpace(_email) || _email.Contains('@', StringComparison.Ordinal)
            ? null
            : "Le format de l’adresse e-mail semble incorrect.";

    private Task ToggleButtonLoadingAsync(MouseEventArgs _)
    {
        _isButtonLoading = !_isButtonLoading;
        _messageInteraction = _isButtonLoading
            ? "L’état de chargement est activé sur le bouton de démonstration."
            : "L’état de chargement est désactivé.";
        return Task.CompletedTask;
    }

    private Task MontrerActionPrincipaleAsync(MouseEventArgs _)
    {
        _messageInteraction = "Action principale déclenchée : en situation réelle, elle lancerait l’opération prioritaire de l’écran.";
        return Task.CompletedTask;
    }

    private Task MontrerActionSecondaireAsync(MouseEventArgs _)
    {
        _messageInteraction = "Action secondaire déclenchée : elle illustre une action utile mais non prioritaire.";
        return Task.CompletedTask;
    }

    private Task MontrerActionNavigationAsync(MouseEventArgs _)
    {
        _messageInteraction = "Action de navigation déclenchée : la variante ghost reste adaptée aux actions discrètes.";
        return Task.CompletedTask;
    }

    private Task MontrerActionDangerAsync(MouseEventArgs _)
    {
        _messageInteraction = "Action sensible déclenchée : la variante danger sert à signaler un impact potentiellement destructif.";
        return Task.CompletedTask;
    }

    private Task MontrerActionPetiteAsync(MouseEventArgs _)
    {
        _messageInteraction = "Le format compact convient aux tableaux, listes denses et zones d’actions secondaires.";
        return Task.CompletedTask;
    }

    private Task MontrerActionGrandeAsync(MouseEventArgs _)
    {
        _messageInteraction = "Le format large sert à renforcer une action importante dans un contexte éditorial ou un pied de page.";
        return Task.CompletedTask;
    }

    private Task ExporterExempleAsync(MouseEventArgs _)
    {
        ConfigurerModale(
            "Exporter le tableau régional",
            "Exemple d’action secondaire sur un en-tête de page.",
            "Dans une interface réelle, cette action préparerait un export PDF, Excel ou CSV du tableau affiché, avec les filtres courants déjà appliqués.");
        return Task.CompletedTask;
    }

    private Task CreerExempleAsync(MouseEventArgs _)
    {
        ConfigurerModale(
            "Créer un élément",
            "Exemple d’action primaire associée à un en-tête de page.",
            "Dans un écran métier, cette action ouvrirait le formulaire de création ou la vue dédiée.");

        return Task.CompletedTask;
    }

    private Task CreerRapportExempleAsync(MouseEventArgs _)
    {
        ConfigurerModale(
            "Créer un premier rapport",
            "Exemple d’action principale sur un état vide.",
            "Le composant peut orienter vers la prochaine étape utile, ici l’ouverture d’un flux de création.");

        return Task.CompletedTask;
    }

    private Task ImporterRapportExempleAsync(MouseEventArgs _)
    {
        ConfigurerModale(
            "Importer des rapports",
            "Exemple d’action secondaire depuis un état vide.",
            "Dans un cas réel, cette action ouvrirait un assistant d’import ou un sélecteur de fichier pour injecter plusieurs rapports existants dans l’interface.");

        return Task.CompletedTask;
    }

    private Task CloseFromButtonAsync(MouseEventArgs _)
    {
        _isModalOpen = false;
        return Task.CompletedTask;
    }

    private Task ConfirmModalAsync(MouseEventArgs _)
    {
        _isModalOpen = false;
        _messageInteraction = "La confirmation a été prise en compte sur l’exemple de modale.";
        return Task.CompletedTask;
    }

    private Task CloseModalAsync()
    {
        _isModalOpen = false;
        return Task.CompletedTask;
    }

    private void ConfigurerModale(string titre, string description, string contenu)
    {
        _titreModale = titre;
        _descriptionModale = description;
        _contenuModale = contenu;
        _isModalOpen = true;
    }
}
