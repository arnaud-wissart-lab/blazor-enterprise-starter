@page "/"
@inject PlatformApiClient PlatformApiClient

<PageTitle>Accueil</PageTitle>

<AppPageHeader Eyebrow="Accueil"
               Title="Vue d’ensemble du projet"
               Description="BlazorEnterpriseStarter est une application de démonstration conçue pour montrer une architecture .NET claire, une interface maîtrisée et un module métier crédible.">
    <Badges>
        <AppBadge Tone="AppTone.Accent">Blazor Web App</AppBadge>
        <AppBadge Tone="AppTone.Info">Interactive Server</AppBadge>
        <AppBadge Tone="AppTone.Neutral">Composants Razor</AppBadge>
        <AppBadge Tone="AppTone.Info">ASP.NET Core</AppBadge>
        <AppBadge Tone="AppTone.Success">.NET Aspire</AppBadge>
    </Badges>
    <Actions>
        <AppButton Href="/backlog">Ouvrir le backlog</AppButton>
        <AppButton Variant="AppButtonVariant.Secondary" Href="/composants">Voir la bibliothèque UI</AppButton>
    </Actions>
    <ChildContent>
        <div class="home-header-stats">
            <div>
                <strong>8</strong>
                <span>projets dans la solution</span>
            </div>
            <div>
                <strong>3</strong>
                <span>sections principales à parcourir</span>
            </div>
            <div>
                <strong>2</strong>
                <span>modes de lancement : Aspire et Docker</span>
            </div>
        </div>
    </ChildContent>
</AppPageHeader>

<div class="home-overview-grid">
    <AppCard Eyebrow="Projet"
             Title="Ce que montre cette application"
             Description="Le dépôt a été structuré pour être compris rapidement par un recruteur technique ou un lead développeur.">
        <ChildContent>
            <ul class="home-list">
                <li>Une application Blazor structurée autour d’un backend ASP.NET Core séparé</li>
                <li>Un design system clair, réutilisable et aligné sur des usages métier</li>
                <li>Un module backlog avec recherche, filtres, pagination et opérations CRUD</li>
                <li>Une exécution locale lisible via Aspire, avec un lancement Docker simple</li>
            </ul>
        </ChildContent>
    </AppCard>

    @if (_isLoading)
    {
        <AppCard Eyebrow="Supervision" Title="État de la plateforme" Description="Le diagnostic du backend apparaît ici après la première vérification.">
            <div class="home-loading-state">
                <AppLoader Label="Vérification du backend" />
                <p>Le contrôle est effectué automatiquement au chargement.</p>
            </div>
        </AppCard>
    }
    else
    {
        <PlatformOverviewCard Status="_status" />
    }
</div>

<section class="home-section">
    <div class="home-section__heading">
        <p class="home-section__eyebrow">Blazor</p>
        <h3>Ce que le front démontre réellement</h3>
        <p>Le projet assume une Blazor Web App en mode Interactive Server pour mettre en avant la composition Razor, l’état local et les interactions métier sans complexifier inutilement le dépôt.</p>
    </div>

    <div class="home-blazor-grid">
        <AppCard Eyebrow="Rendu"
                 Title="Interactive Server assumé"
                 Description="Le rendu interactif côté serveur est un choix volontaire pour privilégier la lisibilité de l’architecture front et la rapidité de démonstration."
                 IsCompact="true">
            <ChildContent>
                <p>Le projet montre un front Blazor crédible dans un contexte back-office ou application interne, avec un HTML initial côté serveur puis une interactivité gérée par le circuit Blazor.</p>
            </ChildContent>
            <Footer>
                <div class="home-tech-tags">
                    <AppBadge Tone="AppTone.Accent">AddInteractiveServerComponents</AppBadge>
                    <AppBadge Tone="AppTone.Info">@@rendermode</AppBadge>
                </div>
            </Footer>
        </AppCard>

        <AppCard Eyebrow="Composants"
                 Title="Architecture Razor par niveaux"
                 Description="Le front sépare le shell, les pages, les composants applicatifs et les fondations visuelles."
                 IsCompact="true">
            <ChildContent>
                <p>Cette organisation rend la lecture rapide pour un recruteur technique et montre que les composants Razor sont pensés comme des briques réutilisables plutôt que comme du code de page dispersé.</p>
            </ChildContent>
            <Footer>
                <div class="home-tech-tags">
                    <AppBadge Tone="AppTone.Neutral">DesignSystem</AppBadge>
                    <AppBadge Tone="AppTone.Info">Components</AppBadge>
                    <AppBadge Tone="AppTone.Success">Pages Razor</AppBadge>
                </div>
            </Footer>
        </AppCard>

        <AppCard Eyebrow="État"
                 Title="État local et interactions utiles"
                 Description="Le backlog met en avant les événements Razor, le binding, le debounce et une orchestration front explicite."
                 IsCompact="true">
            <ChildContent>
                <p>Le dépôt ne surjoue pas le front riche : il montre surtout une gestion d’état pragmatique, des formulaires, des modales et un client API dédié, ce qui est plus convaincant qu’une démo artificiellement complexe.</p>
            </ChildContent>
            <Footer>
                <div class="home-tech-tags">
                    <AppBadge Tone="AppTone.Warning">BacklogState</AppBadge>
                    <AppBadge Tone="AppTone.Accent">Binding</AppBadge>
                    <AppBadge Tone="AppTone.Info">HttpClient</AppBadge>
                </div>
            </Footer>
        </AppCard>
    </div>
</section>

<section class="home-section">
    <div class="home-section__heading">
        <p class="home-section__eyebrow">Parcours</p>
        <h3>Les trois entrées principales</h3>
        <p>Chaque page a un rôle précis pour comprendre rapidement le projet et son niveau de finition.</p>
    </div>

    <div class="home-quick-grid">
        <AppCard Title="Accueil"
                 Description="Présente le périmètre, l’architecture et les accès utiles."
                 IsCompact="true">
            <ChildContent>
                <p>Cette vue sert de point d’entrée pour comprendre le dépôt sans passer immédiatement par le code.</p>
            </ChildContent>
            <Footer>
                <AppBadge Tone="AppTone.Neutral">Vous êtes actuellement sur cette page</AppBadge>
            </Footer>
        </AppCard>

        <AppCard Title="Bibliothèque UI"
                 Description="Expose les fondations visuelles et les composants réutilisables."
                 IsCompact="true">
            <ChildContent>
                <p>La page montre les styles, les champs, les boutons et les états d’interface utilisés dans l’application.</p>
            </ChildContent>
            <Footer>
                <AppButton Href="/composants" Size="AppControlSize.Small">Ouvrir la bibliothèque</AppButton>
            </Footer>
        </AppCard>

        <AppCard Title="Backlog produit"
                 Description="Démontre un cas d’usage métier complet avec état local et API dédiée."
                 IsCompact="true">
            <ChildContent>
                <p>Cette vue concentre la liste, les filtres, la pagination serveur et les opérations de création, mise à jour et suppression.</p>
            </ChildContent>
            <Footer>
                <AppButton Href="/backlog" Variant="AppButtonVariant.Secondary" Size="AppControlSize.Small">Ouvrir le module</AppButton>
            </Footer>
        </AppCard>
    </div>
</section>

<section class="home-section">
    <div class="home-section__heading">
        <p class="home-section__eyebrow">Lecture technique</p>
        <h3>Ce que le dépôt met en évidence</h3>
        <p>Les choix ci-dessous sont visibles dans l’application et lisibles dans la solution.</p>
    </div>

    <div class="home-strengths-grid">
        <AppCard Eyebrow="Architecture" Title="Front-end, backend et contrats séparés" IsCompact="true">
            <p>Les responsabilités sont réparties entre l’interface Blazor, l’API, les contrats partagés et l’orchestration locale.</p>
        </AppCard>

        <AppCard Eyebrow="UI" Title="Design system et composants réutilisables" IsCompact="true">
            <p>Les styles globaux et les composants applicatifs restent distincts pour préserver la cohérence et la maintenabilité.</p>
        </AppCard>

        <AppCard Eyebrow="Exécution" Title="Lancement local simple avec Aspire et Docker" IsCompact="true">
            <p>L’application peut être lancée dans un parcours orchestré ou dans un contexte conteneurisé minimal.</p>
        </AppCard>

        <AppCard Eyebrow="Backlog" Title="État local et flux métier démonstratifs" IsCompact="true">
            <p>Le module backlog montre la séparation entre client API, gestion d’état locale, logique de page et backend applicatif.</p>
        </AppCard>
    </div>
</section>

@code {
    private ApplicationStatusDto _status = ApplicationStatusDto.CreateUnavailable(
        "BlazorEnterpriseStarter.Server",
        "Indéterminé",
        "Aucune vérification n’a encore été effectuée.");

    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        _status = await PlatformApiClient.GetApplicationStatusAsync(CancellationToken.None);
        _isLoading = false;
    }
}
