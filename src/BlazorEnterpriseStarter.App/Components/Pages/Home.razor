@page "/"
@inject PlatformApiClient PlatformApiClient

<PageTitle>Accueil</PageTitle>

<AppPageHeader Eyebrow="Application métier"
               Title="Starter Blazor/.NET pour application métier"
               Description="Un socle avec shell applicatif, design system dédié, API séparée, backlog produit et premiers tests.">
    <Badges>
        <AppBadge Tone="AppTone.Accent">Blazor Web App</AppBadge>
        <AppBadge Tone="AppTone.Info">API ASP.NET Core séparée</AppBadge>
        <AppBadge Tone="AppTone.Success">Bibliothèque UI</AppBadge>
        <AppBadge Tone="AppTone.Neutral">Aspire + Docker</AppBadge>
    </Badges>
    <Actions>
        <AppButton Href="/backlog">Voir le backlog</AppButton>
        <AppButton Variant="AppButtonVariant.Secondary" Href="/composants">Voir la bibliothèque UI</AppButton>
    </Actions>
    <ChildContent>
        <div class="home-hero-points">
            <div class="home-hero-point">
                <strong>Shell applicatif</strong>
                <span>Navigation, en-têtes et états globaux déjà cadrés.</span>
            </div>
            <div class="home-hero-point">
                <strong>Module backlog</strong>
                <span>Recherche, filtres, pagination, API et CRUD déjà raccordés.</span>
            </div>
            <div class="home-hero-point">
                <strong>Socle technique</strong>
                <span>8 projets, tests ciblés et deux modes de lancement.</span>
            </div>
        </div>
    </ChildContent>
</AppPageHeader>

<section class="home-section">
    <div class="home-section__heading">
        <p class="home-section__eyebrow">Repères</p>
        <h2>Repères du dépôt</h2>
        <p>Quelques points utiles pour situer rapidement le périmètre et les parcours disponibles.</p>
    </div>

    <div class="home-proof-grid">
        <AppCard Title="8 projets coordonnés" Description="Une solution .NET découpée par responsabilités utiles." IsCompact="true">
            <div class="home-proof-card">
                <strong>8</strong>
                <span>front, API, contrats, design system, composants, orchestration et tests</span>
            </div>
        </AppCard>

        <AppCard Title="3 parcours principaux" Description="Accueil, bibliothèque UI et backlog produit." IsCompact="true">
            <div class="home-proof-card">
                <strong>3</strong>
                <span>accueil, bibliothèque UI et module backlog</span>
            </div>
        </AppCard>

        <AppCard Title="2 modes de lancement" Description="Aspire pour l’orchestration, Docker pour la stack conteneurisée." IsCompact="true">
            <div class="home-proof-card">
                <strong>2</strong>
                <span>AppHost Aspire pour orchestrer, Docker pour lancer la stack complète</span>
            </div>
        </AppCard>

        <AppCard Title="Tests déjà présents" Description="Build, tests unitaires et E2E ciblés." IsCompact="true">
            <div class="home-proof-card">
                <strong>OK</strong>
                    <span>xUnit, bUnit et E2E sur les comportements principaux</span>
            </div>
        </AppCard>
    </div>
</section>

<section class="home-section">
    <div class="home-section__heading">
        <p class="home-section__eyebrow">Parcours</p>
        <h2>Explorer rapidement les zones utiles</h2>
        <p>Chaque entrée répond à un besoin concret : situer le dépôt, parcourir l’UI ou ouvrir l’écran métier principal.</p>
    </div>

    <div class="home-entry-grid">
        <AppCard Eyebrow="Accueil"
                 Title="Comprendre l’ensemble"
                 Description="Un point d’entrée pour situer le dépôt, ses parcours et son organisation."
                 IsCompact="true">
            <ChildContent>
                <ul class="home-list">
                    <li>vue d’ensemble du dépôt</li>
                    <li>parcours disponibles</li>
                    <li>architecture résumée en quelques blocs</li>
                </ul>
            </ChildContent>
            <Footer>
                <AppBadge Tone="AppTone.Neutral">Page actuelle</AppBadge>
            </Footer>
        </AppCard>

        <AppCard Eyebrow="Bibliothèque UI"
                 Title="Vérifier le design system"
                 Description="Une vraie page de référence pour les fondations visuelles, les composants et les états d’interface."
                 IsCompact="true">
            <ChildContent>
                <ul class="home-list">
                    <li>couleurs, typographie et rythme</li>
                    <li>boutons, champs, badges et loaders</li>
                    <li>modales, empty states et composition d’écran</li>
                </ul>
            </ChildContent>
            <Footer>
                <AppButton Href="/composants" Variant="AppButtonVariant.Secondary" Size="AppControlSize.Small">Voir la bibliothèque UI</AppButton>
            </Footer>
        </AppCard>

        <AppCard Eyebrow="Backlog"
                 Title="Tester un écran métier"
                 Description="Le backlog concentre le parcours métier principal, avec interactions, API et état local."
                 IsCompact="true">
            <ChildContent>
                <ul class="home-list">
                    <li>recherche, filtres et vues rapides</li>
                    <li>liste paginée, statuts et priorités</li>
                    <li>création, édition et suppression via modales</li>
                </ul>
            </ChildContent>
            <Footer>
                <AppButton Href="/backlog" Variant="AppButtonVariant.Secondary" Size="AppControlSize.Small">Voir le backlog</AppButton>
            </Footer>
        </AppCard>
    </div>
</section>

<section class="home-section">
    <div class="home-section__heading">
        <p class="home-section__eyebrow">Architecture</p>
        <h2>Structure du dépôt</h2>
        <p>Le socle s’appuie sur des frontières simples entre front, API, contrats et orchestration.</p>
    </div>

    <div class="home-architecture-grid">
        <AppCard Eyebrow="UI" Title="Blazor Web App structurée" Description="Le front porte le shell, les pages, les composants applicatifs et la navigation." IsCompact="true">
            <ChildContent></ChildContent>
        </AppCard>
        <AppCard Eyebrow="API" Title="Backend ASP.NET Core dédié" Description="Le module backlog passe par une API séparée, lisible et indépendante de l’interface." IsCompact="true">
            <ChildContent></ChildContent>
        </AppCard>
        <AppCard Eyebrow="Contrats" Title="Types partagés explicites" Description="Les contrats communs évitent les duplications entre front, API et tests." IsCompact="true">
            <ChildContent></ChildContent>
        </AppCard>
        <AppCard Eyebrow="Exécution" Title="Aspire et Docker" Description="Aspire pour l’orchestration locale, Docker pour l’exécution en conteneurs." IsCompact="true">
            <ChildContent></ChildContent>
        </AppCard>
    </div>
</section>

<section class="home-section">
    <div class="home-section__heading">
        <p class="home-section__eyebrow">Dès J1</p>
        <h2>Ce qui est déjà en place</h2>
        <p>Le dépôt rassemble déjà les briques utiles pour lancer une application métier.</p>
    </div>

    <div class="home-day-one-grid">
        <AppCard Title="Socle applicatif" Description="Les éléments de structure déjà en place." IsCompact="true">
            <ul class="home-check-list">
                <li>shell applicatif</li>
                <li>navigation structurée</li>
                <li>thème clair/sombre</li>
                <li>états globaux intégrés</li>
            </ul>
        </AppCard>

        <AppCard Title="Design system" Description="Les composants de base déjà uniformisés." IsCompact="true">
            <ul class="home-check-list">
                <li>cartes, boutons et badges</li>
                <li>champs et sélecteurs</li>
                <li>modales et empty states</li>
                <li>feedback et loaders</li>
            </ul>
        </AppCard>

        <AppCard Title="Socle métier" Description="Le backlog sert de parcours métier principal." IsCompact="true">
            <ul class="home-check-list">
                <li>liste métier</li>
                <li>recherche et filtres</li>
                <li>pagination</li>
                <li>création, édition, suppression</li>
            </ul>
        </AppCard>

        <AppCard Title="Base technique" Description="Client API, état local, tests et modes de lancement." IsCompact="true">
            <ul class="home-check-list">
                <li>client API dédié</li>
                <li>état local explicite</li>
                <li>tests unitaires et bUnit</li>
                <li>lancement Aspire et Docker</li>
            </ul>
        </AppCard>
    </div>
</section>

<section class="home-section">
    <div class="home-section__heading">
        <p class="home-section__eyebrow">Plateforme</p>
        <h2>Un contrôle simple, déjà intégré</h2>
        <p>Le contrôle de plateforme permet de vérifier rapidement l’état du backend depuis l’interface.</p>
    </div>

    <div class="home-platform-grid">
        <AppCard Title="Ce que couvre ce bloc"
                 Description="Un résumé court de l’état de la plateforme, sans alourdir la page d’accueil."
                 IsCompact="true">
            <ChildContent>
                <ul class="home-check-list">
                    <li>état du backend</li>
                    <li>environnement courant</li>
                    <li>horodatage du dernier contrôle</li>
                    <li>message de diagnostic</li>
                </ul>
            </ChildContent>
        </AppCard>

        @if (_isLoading)
        {
            <AppCard Eyebrow="Supervision" Title="État de la plateforme" Description="Le diagnostic du backend apparaît ici après la première vérification." IsCompact="true">
                <div class="home-loading-state">
                    <AppLoader Label="Vérification du backend" />
                    <p>Le contrôle est exécuté automatiquement au chargement.</p>
                </div>
            </AppCard>
        }
        else
        {
            <PlatformOverviewCard Status="_status" />
        }
    </div>
</section>

@code {
    private ApplicationStatusDto _status = ApplicationStatusDto.CreateUnavailable(
        "BlazorEnterpriseStarter.Server",
        "Indéterminé",
        "Aucune vérification n’a encore été effectuée.");

    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        _status = await PlatformApiClient.GetApplicationStatusAsync(CancellationToken.None);
        _isLoading = false;
    }
}
