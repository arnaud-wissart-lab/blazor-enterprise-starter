@page "/error"
@using System.Diagnostics

<PageTitle>Erreur</PageTitle>

<div class="bes-page">
    <AppEmptyState Eyebrow="Erreur"
                   Title="Une erreur inattendue est survenue"
                   Description="Le chargement de cette page a été interrompu avant son affichage complet."
                   Tone="AppTone.Danger">
        <Actions>
            <AppButton Href="/" Variant="AppButtonVariant.Secondary">Revenir à l’accueil</AppButton>
            <AppButton Href="." Variant="AppButtonVariant.Ghost">Recharger</AppButton>
        </Actions>
        <ChildContent>
            @if (ShowRequestId)
            {
                <p>
                    <strong>Identifiant de requête :</strong>
                    <code>@RequestId</code>
                </p>
            }

            <p>
                Si le problème persiste, revenez à l’accueil puis relancez la navigation depuis les entrées principales de l’application.
            </p>
        </ChildContent>
    </AppEmptyState>
</div>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }

    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
