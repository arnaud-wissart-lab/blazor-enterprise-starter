@page "/error"
@using System.Diagnostics

<PageTitle>Erreur</PageTitle>

<div class="bes-page">
    <AppEmptyState Eyebrow="Erreur"
                   Title="Une erreur inattendue est survenue"
                   Description="Une exception non gérée a interrompu le traitement de la requête. La page d’erreur reste volontairement simple, mais alignée sur le reste de l’interface."
                   Tone="AppTone.Danger">
        <Actions>
            <AppButton Href="/" Variant="AppButtonVariant.Secondary">Revenir à l’accueil</AppButton>
        </Actions>
        <ChildContent>
            @if (ShowRequestId)
            {
                <p>
                    <strong>Identifiant de requête :</strong>
                    <code>@RequestId</code>
                </p>
            }

            <p>
                En environnement <strong>Development</strong>, l’application affiche davantage de détails pour faciliter
                le diagnostic local. Ce mode ne doit pas être utilisé sur une application déployée.
            </p>
        </ChildContent>
    </AppEmptyState>
</div>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }

    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
