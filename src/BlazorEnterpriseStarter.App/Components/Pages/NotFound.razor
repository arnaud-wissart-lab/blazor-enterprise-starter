@page "/not-found"
@layout MainLayout

<PageTitle>Page introuvable</PageTitle>

<AppEmptyState Eyebrow="Navigation"
               Title="Page introuvable"
               Description="Le contenu demandé n’existe pas encore ou l’adresse saisie n’est pas valide."
               Tone="AppTone.Warning">
    <Actions>
        <AppButton Href="/" Variant="AppButtonVariant.Secondary">Retour à l’accueil</AppButton>
        <AppButton Href="/backlog">Voir le backlog</AppButton>
    </Actions>
    <ChildContent>
        Vérifiez l’URL ou reprenez la navigation depuis les entrées principales de l’application.
    </ChildContent>
</AppEmptyState>
